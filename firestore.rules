rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Profile is writable only by its owner; readable by any signed-in user
    // since group members need to see each other's display name/avatar (FR-5.1).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Group metadata is readable by any signed-in user so an invite code can be looked
    // up before joining; only the creator can rename/delete (FR-2.5).
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.creatorId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.creatorId;
    }

    // Membership doc IDs are `${userId}_${groupId}` by convention. Read is left open to
    // any signed-in user (v1 simplification of FR-2.7) rather than checking group
    // membership per-read. Create is self-service; delete is self (leave) or the group's
    // creator (remove member).
    match /groupMemberships/{membershipId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if false;
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        request.auth.uid == get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.creatorId
      );
    }

    // Doc IDs are `${userId}_${date}`, which combined with create-only (no update)
    // enforces one attempt per calendar day at the database level too (FR-3.6).
    // Read is open to any signed-in user (v1 simplification of FR-5.1/NFR-7, matching
    // the same tradeoff made for groups/groupMemberships) rather than checking shared
    // group membership per-read.
    match /plankAttempts/{attemptId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false;
    }
  }
}
