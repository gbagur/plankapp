rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Profile is writable only by its owner; readable by any signed-in user
    // since group members need to see each other's display name/avatar (FR-5.1).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
